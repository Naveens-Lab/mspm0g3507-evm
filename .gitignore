# KiCad .gitignore — MSPM0 DevBoard
# Reference: https://kicad.org/help/file-formats/

# ── Lock files (created when KiCad has files open) ──────────────
~*
*~
*.lck

# ── Backup files ─────────────────────────────────────────────────
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*-bak

# ── KiCad auto-generated cache ───────────────────────────────────
fp-info-cache
*-cache*

# ── KiCad backup folders ─────────────────────────────────────────
*-backups/

# ── Local project/session settings (machine-specific) ────────────
*.kicad_prl
.history

# ── Auto-save / temp ─────────────────────────────────────────────
_autosave-*
*.tmp
\#auto_saved_files#
*-save.pro
*-save.kicad_pcb

# ── Exported outputs (regenerate from source) ────────────────────
*.net
*.dsn
*.ses
*.xml
*.csv
*.000
